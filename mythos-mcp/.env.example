# Transport: http (Perplexity connector) or stdio (traditional MCP client)
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=7777

# LangGraph / Mythos flow runner
MYTHOS_FLOW_URL=http://127.0.0.1:8100
MYTHOS_API_KEY=

# WADE agent/KB endpoint
WADE_AGENT_URL=http://127.0.0.1:8787/query
# alias supported by code: WADE_URL
WADE_API_KEY=

# Supabase relay mode A: direct relay URL (matches your snippet)
SUPABASE_RELAY_URL=

# Supabase relay mode B: RPC
SUPABASE_URL=https://rjcoeoropwvqzvinopze.supabase.co
SUPABASE_COMMAND_RELAY_RPC=command_relay
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
